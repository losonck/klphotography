<!-- src/pages/privacy.astro — Phase 5 (05-03) GDPR Art 13 policy per RESEARCH §10 + D-11.
     Route, BaseLayout wrapper, Nav, Section tone, Footer (slot content) carried verbatim from Phase 3.
     Phase 3 robots-blocking meta REMOVED (real policy is publicly indexable per GDPR Art 12 transparency).
     [OWNER-CONFIRM:*] markers must be resolved before Phase 6 production deploy. -->
---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Nav from '@/components/ui/Nav.astro';
import Section from '@/components/ui/Section.astro';
import Footer from '@/components/ui/Footer.astro';
import SocialIcons from '@/components/icons/SocialIcons.astro';
---

<BaseLayout
  title="Privacy policy — KL Photography"
  description="How KL Photography handles personal data submitted via the contact form."
>
  <Nav />

  <Section id="privacy" tone="cream">
    <h1>Privacy policy</h1>
    <p class="text-sm text-ink-soft">Last updated: 2026-05-18</p>

    <h2>Data controller</h2>
    <p>KL Photography</p>
    <p>Operated by Karl L.</p>
    <p>Dublin D13, Ireland</p>
    <p>Email: <a href="mailto:klphotography.ie@gmail.com" class="text-bronze hover:text-bronze-hover underline">klphotography.ie@gmail.com</a></p>

    <h2>What data we collect</h2>
    <table class="mt-4 w-full border-collapse text-left">
      <thead>
        <tr class="border-b border-rule">
          <th class="py-2 pr-4 font-serif">Field</th>
          <th class="py-2 pr-4 font-serif">Personal data?</th>
          <th class="py-2 font-serif">Required</th>
        </tr>
      </thead>
      <tbody>
        <tr class="border-b border-rule">
          <td class="py-2 pr-4">Name</td>
          <td class="py-2 pr-4">Yes</td>
          <td class="py-2">Required</td>
        </tr>
        <tr class="border-b border-rule">
          <td class="py-2 pr-4">Email address</td>
          <td class="py-2 pr-4">Yes</td>
          <td class="py-2">Required</td>
        </tr>
        <tr class="border-b border-rule">
          <td class="py-2 pr-4">Wedding date</td>
          <td class="py-2 pr-4">No</td>
          <td class="py-2">Optional</td>
        </tr>
        <tr class="border-b border-rule">
          <td class="py-2 pr-4">Venue</td>
          <td class="py-2 pr-4">No</td>
          <td class="py-2">Optional</td>
        </tr>
        <tr>
          <td class="py-2 pr-4">Message</td>
          <td class="py-2 pr-4">Potentially</td>
          <td class="py-2">Required</td>
        </tr>
      </tbody>
    </table>
    <p class="mt-6">We do not collect anything else. The contact form does not write cookies and we use no third-party tracking scripts beyond Cloudflare Turnstile (spam protection) and Cloudflare Web Analytics (cookieless page performance metrics — see Cookies and analytics below).</p>

    <h2>Why we process this data (purpose and legal basis)</h2>
    <p>Purpose: To respond to your enquiry about wedding photography services.</p>
    <p>Legal basis: Pre-contractual measures (GDPR Article 6(1)(b)) — your enquiry is a step toward a possible photography contract.</p>

    <h2>Data processors</h2>
    <table class="mt-4 w-full border-collapse text-left">
      <thead>
        <tr class="border-b border-rule">
          <th class="py-2 pr-4 font-serif">Processor</th>
          <th class="py-2 pr-4 font-serif">Role</th>
          <th class="py-2 pr-4 font-serif">Location</th>
          <th class="py-2 font-serif">Privacy policy</th>
        </tr>
      </thead>
      <tbody>
        <tr class="border-b border-rule align-top">
          <td class="py-2 pr-4">Cloudflare, Inc.</td>
          <td class="py-2 pr-4">Website hosting, form infrastructure, spam protection (Turnstile), cookieless analytics</td>
          <td class="py-2 pr-4">USA (SCCs apply)</td>
          <td class="py-2"><a href="https://www.cloudflare.com/privacypolicy/" class="text-bronze hover:text-bronze-hover underline">cloudflare.com/privacypolicy</a></td>
        </tr>
        <tr class="border-b border-rule align-top">
          <td class="py-2 pr-4">Resend, Inc.</td>
          <td class="py-2 pr-4">Email delivery of your enquiry to the photographer</td>
          <td class="py-2 pr-4">USA (SCCs apply)</td>
          <td class="py-2"><a href="https://resend.com/legal/privacy-policy" class="text-bronze hover:text-bronze-hover underline">resend.com/legal/privacy-policy</a></td>
        </tr>
        <tr class="align-top">
          <td class="py-2 pr-4">Google LLC (Gmail)</td>
          <td class="py-2 pr-4">Storage of the received email in the photographer's mailbox</td>
          <td class="py-2 pr-4">USA (SCCs apply)</td>
          <td class="py-2"><a href="https://policies.google.com/privacy" class="text-bronze hover:text-bronze-hover underline">policies.google.com/privacy</a></td>
        </tr>
      </tbody>
    </table>

    <h2>How long we keep your data (retention)</h2>
    <p>We retain your enquiry data in our email inbox for up to 12 months, or until a booking is confirmed or declined — whichever comes first. After that, we delete it from active correspondence. You may request earlier deletion at any time by emailing <a href="mailto:klphotography.ie@gmail.com" class="text-bronze hover:text-bronze-hover underline">klphotography.ie@gmail.com</a>.</p>

    <h2>Your rights under GDPR</h2>
    <p>Under the General Data Protection Regulation you have the right to:</p>
    <ul class="mt-4 list-disc pl-6 space-y-2">
      <li>Access the personal data we hold about you (Article 15)</li>
      <li>Correct any inaccurate data (Article 16)</li>
      <li>Request deletion ("right to be forgotten", Article 17)</li>
      <li>Restrict how we process your data (Article 18)</li>
      <li>Object to our processing (Article 21)</li>
      <li>Data portability (Article 20)</li>
      <li>Lodge a complaint with the supervisory authority (Article 77)</li>
    </ul>
    <p class="mt-4">To exercise any of these rights, email <a href="mailto:klphotography.ie@gmail.com" class="text-bronze hover:text-bronze-hover underline">klphotography.ie@gmail.com</a>.</p>

    <h2>Cookies and analytics</h2>
    <p>This website sets zero cookies and uses no local storage. We use Cloudflare Web Analytics for cookieless page performance metrics — this beacon does not set cookies, does not use localStorage, does not log your IP address, and does not track you across sites. For details see <a href="https://developers.cloudflare.com/web-analytics/" class="text-bronze hover:text-bronze-hover underline">developers.cloudflare.com/web-analytics</a>.</p>

    <h2>International data transfers</h2>
    <p>Our processors (Cloudflare, Resend, Google) are based in the United States. These transfers rely on Standard Contractual Clauses under GDPR Article 46. Each processor publishes its data transfer documentation at the links in the Processors section above.</p>

    <h2>Automated decision-making</h2>
    <p>We do not use automated profiling or automated decision-making (GDPR Article 13(2)(f)).</p>

    <h2>Supervisory authority</h2>
    <p>If you have concerns about how we handle your personal data, you may contact the Irish Data Protection Commission:</p>
    <!-- [OWNER-CONFIRM] Verify DPC contact details at dataprotection.ie before launch per RESEARCH A4 -->
    <address class="not-italic mt-4 space-y-1">
      <p>Data Protection Commission (DPC)</p>
      <p>21 Fitzwilliam Square South</p>
      <p>Dublin 2, D02 RD28</p>
      <p>Ireland</p>
      <p>Phone: +353 (0)761 104 800</p>
      <p>Web: <a href="https://www.dataprotection.ie" class="text-bronze hover:text-bronze-hover underline">www.dataprotection.ie</a></p>
      <p>Complaint form: <a href="https://www.forms.dataprotection.ie/raise-a-concern" class="text-bronze hover:text-bronze-hover underline">forms.dataprotection.ie/raise-a-concern</a></p>
    </address>

    <h2>Changes to this policy</h2>
    <p>We may update this policy from time to time. The "Last updated" date at the top of this page reflects the most recent revision.</p>
  </Section>

  <Footer>
    <p slot="brand" class="font-serif text-xl text-ink">KL Photography</p>
    <ul slot="links" class="space-y-2">
      <li><a href="/" class="hover:text-bronze">Home</a></li>
      <li><a href="/#about" class="hover:text-bronze">About</a></li>
      <li><a href="/#pricing" class="hover:text-bronze">Pricing</a></li>
      <li><a href="/#testimonials" class="hover:text-bronze">Testimonials</a></li>
      <li><a href="/#contact" class="hover:text-bronze">Contact</a></li>
      <li><a href="/privacy" class="hover:text-bronze">Privacy</a></li>
    </ul>
    <div slot="social" class="flex gap-4">
      <a href="https://instagram.com/klphotography.ie" aria-label="Instagram" class="motion-safe:transition-colors hover:text-bronze">
        <SocialIcons brand="instagram" />
      </a>
      <a href="https://facebook.com/klphotography.ie" aria-label="Facebook" class="motion-safe:transition-colors hover:text-bronze">
        <SocialIcons brand="facebook" />
      </a>
      <a href="https://wa.me/353851665472" aria-label="WhatsApp" class="motion-safe:transition-colors hover:text-bronze">
        <SocialIcons brand="whatsapp" />
      </a>
    </div>
  </Footer>
</BaseLayout>
