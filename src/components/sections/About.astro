<!-- [OWNER-REVIEW] About — first-person photographer story per CONTENT-02 -->
---
import { Image } from 'astro:assets';
import Section from '@/components/ui/Section.astro';
import Button from '@/components/ui/Button.astro';
import portrait from '@/assets/placeholder/about-portrait.jpg';
---

<Section id="about" tone="cream">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
    <div class="order-2 lg:order-1">
      <h2>I photograph the day the way you'll remember it.</h2>
      <p class="mt-6">
        Hi, I'm [OWNER-CONFIRM:first-name]. I've been photographing weddings across Ireland for [OWNER-CONFIRM:years] — most of them in Dublin, the rest from Donegal to Cork.
      </p>
      <p class="mt-4">
        My approach is quiet. I don't pose; I watch. The look you give your dad before walking down the aisle, the laugh that breaks during the speeches, the slow second when the band starts and the floor finally fills — those are the photos you'll look at in twenty years. Everything else is filler.
      </p>
      <p class="mt-4">
        I'll arrive early, stay late, and ask exactly two things of you on the day: trust me to find the moments, and don't worry about the camera. The day is yours. I'm just lucky enough to keep it.
      </p>
      <p class="text-ink-soft text-sm mt-6">
        Based in Dublin · Available across Ireland · [OWNER-REVIEW] optional fact
      </p>
      <Button as="a" href="#contact" variant="secondary" size="md" class="mt-8">Get in touch</Button>
    </div>
    <div class="order-1 lg:order-2">
      <Image
        src={portrait}
        widths={[480, 720, 960]}
        sizes="(min-width: 1024px) 50vw, 100vw"
        alt="[OWNER-REVIEW] placeholder portrait — photographer to provide before launch"
        loading="lazy"
        decoding="async"
        class="w-full h-auto"
      />
    </div>
  </div>
</Section>
