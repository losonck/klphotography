<!-- [OWNER-REVIEW] Testimonials — 3 quotes (1 verified from existing Wix site, 2 placeholder) per CONTENT-04. Pull-quotes use EB Garamond italic. -->
---
import Section from '@/components/ui/Section.astro';
---

<Section id="testimonials" tone="cream">
  <h2>What couples say</h2>
  <div class="mt-12 grid grid-cols-1 lg:grid-cols-3 gap-12">
    <!-- [VERIFIED: from existing klphotography.ie Wix site — do not remove as placeholder] -->
    <figure>
      <span class="font-serif text-5xl text-bronze leading-none" aria-hidden="true">&ldquo;</span>
      <blockquote class="font-serif italic text-lg mt-4">The photos are amazing. Thank you so much for capturing our day and all the beautiful memories. Your approach was so discreet and the whole process was easy from start to finish.</blockquote>
      <figcaption class="mt-6 text-sm text-ink-soft not-italic">&mdash; Louise &amp; Jonathan</figcaption>
    </figure>

    <!-- [OWNER-REVIEW] Placeholder — owner to replace with real testimonial -->
    <figure>
      <span class="font-serif text-5xl text-bronze leading-none" aria-hidden="true">&ldquo;</span>
      <blockquote class="font-serif italic text-lg mt-4">We can't recommend [OWNER-CONFIRM:first-name] enough. The photos felt like the day itself — not posed, not staged, just us. Two months on and we still find new favourites every time we open the gallery.</blockquote>
      <figcaption class="mt-6 text-sm text-ink-soft not-italic">&mdash; [OWNER-CONFIRM:couple-names], [OWNER-CONFIRM:venue]</figcaption>
    </figure>

    <!-- [OWNER-REVIEW] Placeholder — owner to replace with real testimonial -->
    <figure>
      <span class="font-serif text-5xl text-bronze leading-none" aria-hidden="true">&ldquo;</span>
      <blockquote class="font-serif italic text-lg mt-4">Calm presence on a busy day. We barely noticed the camera, which is exactly what we wanted, and then the photos arrived and we cried. Both sets of parents have ordered prints.</blockquote>
      <figcaption class="mt-6 text-sm text-ink-soft not-italic">&mdash; [OWNER-CONFIRM:couple-names], [OWNER-CONFIRM:venue]</figcaption>
    </figure>
  </div>
</Section>
