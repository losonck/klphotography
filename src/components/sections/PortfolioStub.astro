<!-- [OWNER-REVIEW] Phase 4 will replace this stub with the real gallery; the #portfolio anchor target is shipped now so the smooth-scroll set up in Plan 03-03 has somewhere to land. -->
---
import { getCollection } from 'astro:content';
import Section from '@/components/ui/Section.astro';

// Plan 04-01: surface the current intake count from the gallery content collection.
// The glob loader in src/content.config.ts runs at build/sync time and Zod validates
// every entry then — invalid entries fail the whole build with an InvalidContentEntryDataError
// naming the offending file and field (GALLERY-05 alt-lint enforcement, proven by
// Plan 04-01 Task 6's break/fix test). 04-02 will replace this stub with the real gallery.
const galleryCount = (await getCollection('gallery')).length;
---

<Section id="portfolio" tone="cream-deep">
  <h2>Selected work</h2>
  <p class="mt-6">
    {galleryCount} curated photos are queued in the content collection — the full gallery launches in Phase 4-02.
    In the meantime, find recent work on
    <a href="https://instagram.com/klphotography.ie" class="text-bronze hover:text-bronze-hover underline">Instagram</a>.
  </p>
</Section>
