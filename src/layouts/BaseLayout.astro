---
import '@/styles/global.css';
import { Font } from 'astro:assets';
import SeoHead from '@/components/seo/SeoHead.astro';
import LocalBusinessSchema from '@/components/seo/LocalBusinessSchema.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonicalUrl?: string;
}

const { title, description, ogImage, canonicalUrl } = Astro.props;

// Plan 05-03: CF Web Analytics token is sourced from build-time env per D-10
// (Astro PUBLIC_* convention exposes to browser at build time).
// Deviation from plan text: the beacon is rendered CONDITIONALLY (only when the
// env var is set + non-empty). The plan template would have rendered
// data-cf-beacon='{"token": "undefined"}' when unset — CF beacon silently
// ignores invalid tokens, but the literal "undefined" string in HTML is noise
// and slightly misleading on view-source. Owner constraint: token cannot be
// provisioned until Phase 6 DNS-03 puts klphotography.ie on Cloudflare and the
// Web Analytics site is created. Until then, render NOTHING — zero third-party
// script, zero cookies, zero "undefined" literal in built HTML. After Phase 6
// owner sets PUBLIC_CF_ANALYTICS_TOKEN in CF Pages env (Preview + Production)
// and the next build emits the beacon.
const cfAnalyticsToken = import.meta.env.PUBLIC_CF_ANALYTICS_TOKEN;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <Font cssVariable="--font-serif" preload />
    <Font cssVariable="--font-sans" />
    <!-- Phase 6 (06-01) SEO meta: canonical + OG + Twitter card + apple-touch-icon.
         Placed AFTER font preloads (critical path order preserved) and BEFORE the
         per-page <slot name="head"> so a page could override or augment if ever needed. -->
    <SeoHead title={title} description={description} ogImage={ogImage} canonicalUrl={canonicalUrl} />
    <LocalBusinessSchema />
    <!-- Slot ordering: placed after <Font /> preloads so injected <link rel="preload"> from pages do not preempt critical font preloads. Phase 6 SEO meta should preserve this order. -->
    <slot name="head" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body class="bg-cream text-ink font-sans antialiased">
    {/* IntersectionObserver target for sticky-nav scrolled-state (Plan 03-03 + RESEARCH §6).
       1px tall, absolutely positioned, contributes zero layout / zero CLS. */}
    <div data-nav-sentinel aria-hidden="true" style="position: absolute; top: 0; height: 1px; width: 100%; pointer-events: none;"></div>
    <slot />
    <!-- Analytics beacon placed AFTER content (defer) so it never blocks rendering. data-nav-sentinel above and main <slot/> above remain in their Phase 3 positions. -->
    <!-- CF Web Analytics beacon — cookieless, no localStorage; satisfies GDPR-02, GDPR-03. -->
    {cfAnalyticsToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfAnalyticsToken}"}`}
        is:inline
      ></script>
    )}
  </body>
</html>
